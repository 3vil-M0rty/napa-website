# ─── Server ───────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/napa_chapter_one

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=VERY_LONG_RANDOM_SECRET_KEY_HERE
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
FRONTEND_URL=https://yourfrontenddomain.com

# ─── Email (Nodemailer) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="NAPA Chapter One <reservations@napachapterone.com>"

# ─── Internationalization ─────────────────────────────────
SUPPORTED_LANGUAGES=en,fr
DEFAULT_LANGUAGE=en